<Page x:Class="AgentAIStudio.Views.ImagesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:AgentAIStudio.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,8" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock Text="Image Generation" FontSize="20" FontWeight="SemiBold" />
        </Border>

        <!-- Controls row -->
        <Border Grid.Row="1" Padding="16,8">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="PromptBox"
                             Text="{x:Bind ViewModel.Prompt, Mode=TwoWay}"
                             PlaceholderText="Describe the image you want to generate..."
                             AcceptsReturn="False" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="🔄 Advanced" x:Name="AdvancedToggle"
                            Click="OnAdvancedToggle" />
                    <Button Grid.Column="2" Content="Generate" Width="120" Height="40"
                            Command="{x:Bind ViewModel.GenerateCommand}"
                            IsEnabled="{x:Bind ViewModel.IsGenerating, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>

                <!-- Quick settings row -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="ModelSelector"
                              SelectedItem="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
                              SelectedIndex="1" Width="200" />
                    <ComboBox Grid.Column="1" x:Name="SizeSelector" Width="140"
                              SelectedItem="{x:Bind ViewModel.SelectedSize, Mode=TwoWay}" />
                </Grid>

                <!-- Advanced panel -->
                <controls:AdvancedSettingsPanel x:Name="AdvancedPanel"
                                                Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- Results gallery -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Results}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="16" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Padding="8"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                            <StackPanel Spacing="4">
                                <Image Source="{Binding Url}" Stretch="Uniform"
                                       MaxHeight="400" CornerRadius="4" />
                                <controls:MediaActionBar MediaUrl="{Binding Url}"
                                                         ModelName="{Binding Model}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
