<Page x:Class="AgentAIStudio.Views.ChatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:AgentAIStudio.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,8" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid>
                <TextBlock Text="Chat" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="✚ New" HorizontalAlignment="Right"
                        Command="{x:Bind ViewModel.NewConversationCommand}" />
            </Grid>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessageList" ItemsSource="{x:Bind ViewModel.Messages}"
                          Padding="16,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:MessageBubble />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input area -->
        <Border Grid.Row="2" Padding="16,8" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Image attachment preview -->
                <Border x:Name="AttachmentPreview" Grid.Row="0"
                        Visibility="Collapsed" Margin="0,0,0,4"
                        CornerRadius="8" Padding="8"
                        Background="{ThemeResource SystemControlBackgroundChromeLowBrush}">
                    <Grid>
                        <TextBlock x:Name="AttachmentName" VerticalAlignment="Center" />
                        <Button Content="✕" HorizontalAlignment="Right"
                                Command="{x:Bind ViewModel.ClearAttachedImageCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="📎" Width="40" Height="40"
                            Command="{x:Bind ViewModel.AttachImageCommand}"
                            ToolTipService.ToolTip="Attach image for vision understanding" />

                    <TextBox Grid.Column="1" x:Name="InputBox"
                             Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Type a message..." AcceptsReturn="False"
                             VerticalAlignment="Center" IsEnabled="{x:Bind ViewModel.IsStreaming, Converter={StaticResource InverseBoolConverter}, Mode=OneWay}" />

                    <Button Grid.Column="2" Content="Send" Width="80" Height="40"
                            Command="{x:Bind ViewModel.SendMessageCommand}"
                            IsEnabled="{x:Bind ViewModel.IsStreaming, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
