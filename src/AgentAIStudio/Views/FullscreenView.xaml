<Page x:Class="AgentAIStudio.Views.FullscreenView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid Background="Black" Tapped="OnTapped">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Close button -->
        <Button Grid.Row="0" Content="✕ Close" HorizontalAlignment="Right"
                Margin="0,8,8,0" Click="OnClose" Opacity="0.6" />

        <!-- Image -->
        <Image Grid.Row="1" x:Name="FullscreenImage"
               Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Video -->
        <MediaPlayerElement Grid.Row="1" x:Name="FullscreenVideo"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="800" />

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Spacing="8" Margin="0,0,0,16" Opacity="0.6">
            <Button Content="⬇ Download" Click="OnDownload" />
            <Button Content="✏ Edit Further" x:Name="EditBtn" Click="OnEditFurther" />
        </StackPanel>
    </Grid>
</Page>
