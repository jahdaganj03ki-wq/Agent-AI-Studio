<Page x:Class="AgentAIStudio.Views.ImageStudioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:AgentAIStudio.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,8" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Image Studio" FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Upload images and iterate with prompts"
                           FontSize="12" Opacity="0.6" Margin="12,0,0,0"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="✚ New"
                            Command="{x:Bind ViewModel.NewConversationCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Message thread -->
        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                      VerticalScrollBarVisibility="Auto" Padding="16,8">
            <ItemsControl x:Name="MessageList"
                          ItemsSource="{x:Bind ViewModel.Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:ImageStudioBubble />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input area -->
        <Border Grid.Row="2" Padding="16,8"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Spacing="8">
                <!-- Upload indicators -->
                <StackPanel x:Name="UploadPreview" Orientation="Horizontal" Spacing="8"
                            Visibility="Collapsed">
                    <Border CornerRadius="4" Padding="8,4"
                            Background="{ThemeResource SystemControlBackgroundChromeLowBrush}">
                        <TextBlock x:Name="UploadLabel" FontSize="12" />
                    </Border>
                    <Button Content="✕" FontSize="10" Height="20" Width="20"
                            Click="OnClearUploads" />
                </StackPanel>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                        <Button Content="📷 Upload" Width="80"
                                Command="{x:Bind ViewModel.UploadSourceImageCommand}"
                                ToolTipService.ToolTip="Upload a single image to edit" />
                        <Button Content="📚 Multi" Width="80"
                                Command="{x:Bind ViewModel.UploadMultipleImagesCommand}"
                                ToolTipService.ToolTip="Upload multiple images for composition" />
                    </StackPanel>

                    <TextBox Grid.Column="1" x:Name="PromptBox"
                             Text="{x:Bind ViewModel.InputPrompt, Mode=TwoWay}"
                             PlaceholderText="Describe the image or edit you want..."
                             AcceptsReturn="False" VerticalAlignment="Center" />

                    <Button Grid.Column="2" Content="🎨 Generate"
                            Width="100" Height="40"
                            Command="{x:Bind ViewModel.GenerateOrEditCommand}"
                            IsEnabled="{x:Bind ViewModel.IsGenerating, Converter={StaticResource InverseBoolConverter}}" />

                    <Button Grid.Column="3" Content="⚙"
                            Width="40" Height="40"
                            Click="OnAdvancedToggle"
                            ToolTipService.ToolTip="Advanced settings" />
                </Grid>

                <!-- Model/Size quick select -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" x:Name="ModelCombo" Width="180"
                              SelectedItem="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}" />
                    <ComboBox Grid.Column="1" x:Name="SizeCombo" Width="120"
                              SelectedItem="{x:Bind ViewModel.SelectedSize, Mode=TwoWay}" />
                    <Button Grid.Column="2" Content="↻" Width="36"
                            Click="OnResetToTextToImage"
                            ToolTipService.ToolTip="Reset to text-to-image mode" />
                </Grid>

                <!-- Advanced settings -->
                <controls:AdvancedSettingsPanel x:Name="AdvancedPanel"
                                                Visibility="Collapsed" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
