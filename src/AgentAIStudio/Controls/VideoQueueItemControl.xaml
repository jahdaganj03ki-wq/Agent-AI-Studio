<UserControl x:Class="AgentAIStudio.Controls.VideoQueueItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:AgentAIStudio.Converters">
    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor" />
        <conv:StatusToTextConverter x:Key="StatusToText" />
    </UserControl.Resources>
    <Border CornerRadius="8" Padding="8" Margin="0,2"
            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <Ellipse Width="10" Height="10"
                         Fill="{Binding Status, Converter={StaticResource StatusToColor}}" />
                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                           FontWeight="SemiBold" FontSize="12" />
                <TextBlock Text="{Binding Prompt, Converter={StaticResource TruncateConverter}}"
                           FontSize="12" Opacity="0.7" />
            </StackPanel>

            <ProgressBar Grid.Row="1" Value="{Binding Progress}"
                         Maximum="100" Visibility="{Binding IsCompleted, Converter={StaticResource InverseVisibility}}"
                         Height="3" Margin="0,4" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Visibility="Collapsed"
                        x:Name="CompletedActions">
                <Button Content="▶ Play" FontSize="12" Click="OnPlayClick" />
                <Button Content="⬇ Download" FontSize="12" Click="OnDownloadClick" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
