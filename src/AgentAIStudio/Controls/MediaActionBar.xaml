<UserControl x:Class="AgentAIStudio.Controls.MediaActionBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid HorizontalAlignment="Stretch" Margin="0,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" x:Name="ModelLabel"
                   FontSize="11" Opacity="0.6" VerticalAlignment="Center" />

        <Button Grid.Column="1" x:Name="EditFurtherBtn" Content="✏ Edit Further"
                FontSize="12" Margin="4,0" Click="OnEditFurtherClick"
                Style="{StaticResource ActionButtonStyle}" />

        <Button Grid.Column="2" x:Name="RegenerateBtn" Content="🔄 Regenerate"
                FontSize="12" Margin="4,0" Click="OnRegenerateClick"
                Style="{StaticResource ActionButtonStyle}" />

        <Button Grid.Column="3" x:Name="FullscreenBtn" Content="⛶ Fullscreen"
                FontSize="12" Margin="4,0" Click="OnFullscreenClick"
                Style="{StaticResource ActionButtonStyle}" />

        <Button Grid.Column="4" x:Name="DownloadBtn" Content="⬇ Download"
                FontSize="12" Margin="4,0" Click="OnDownloadClick"
                Style="{StaticResource ActionButtonStyle}" />
    </Grid>
</UserControl>
