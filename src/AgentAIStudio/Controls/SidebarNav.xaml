<UserControl x:Class="AgentAIStudio.Controls.SidebarNav"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64">
    <Grid Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Height="48" Background="Transparent">
            <TextBlock Text="🅰" FontSize="24"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <StackPanel Grid.Row="1" x:Name="NavItems" Spacing="2" Margin="0,8,0,0">
            <Button x:Name="ChatBtn" Tag="chat" Click="OnNavClick"
                    Width="48" Height="48" Style="{StaticResource NavButtonStyle}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="Chat" FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="ImagesBtn" Tag="images" Click="OnNavClick"
                    Width="48" Height="48" Style="{StaticResource NavButtonStyle}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🖼" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="Images" FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="VideoBtn" Tag="video" Click="OnNavClick"
                    Width="48" Height="48" Style="{StaticResource NavButtonStyle}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🎬" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="Video" FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="ImageStudioBtn" Tag="imagestudio" Click="OnNavClick"
                    Width="48" Height="48" Style="{StaticResource NavButtonStyle}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🎨" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="Studio" FontSize="9" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Button x:Name="SettingsBtn" Grid.Row="3" Tag="settings" Click="OnNavClick"
                Width="48" Height="48" Margin="0,0,0,8" Style="{StaticResource NavButtonStyle}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⚙" FontSize="20" HorizontalAlignment="Center" />
                <TextBlock Text="Settings" FontSize="9" HorizontalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
