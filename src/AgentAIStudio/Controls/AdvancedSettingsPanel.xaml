<UserControl x:Class="AgentAIStudio.Controls.AdvancedSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
            CornerRadius="8" Padding="12" Margin="0,8">
        <StackPanel Spacing="8">
            <!-- Chat parameters -->
            <StackPanel x:Name="ChatPanel" Visibility="Collapsed">
                <TextBlock Text="Temperature" FontSize="12" />
                <Slider x:Name="TemperatureSlider" Minimum="0" Maximum="2" StepFrequency="0.1"
                        Value="0.7" Width="200" HorizontalAlignment="Left" />
                <TextBlock Text="Top P" FontSize="12" />
                <Slider x:Name="TopPSlider" Minimum="0" Maximum="1" StepFrequency="0.05"
                        Value="1.0" Width="200" HorizontalAlignment="Left" />
                <TextBox x:Name="MaxTokensBox" Header="Max Tokens" Text="4096"
                         Width="120" HorizontalAlignment="Left" />
                <ToggleSwitch x:Name="ThinkingToggle" Header="Thinking Mode" IsOn="False" />
            </StackPanel>

            <!-- Image parameters -->
            <StackPanel x:Name="ImagePanel" Visibility="Collapsed">
                <ComboBox x:Name="SizeCombo" Header="Size" Width="140" HorizontalAlignment="Left"
                          SelectedIndex="0" />
                <TextBox x:Name="SeedBox" Header="Seed (optional)" PlaceholderText="Leave empty for random"
                         Width="140" HorizontalAlignment="Left" />
                <ComboBox x:Name="ModelCombo" Header="Model" Width="200" HorizontalAlignment="Left"
                          SelectedIndex="0" />
            </StackPanel>

            <!-- Video parameters -->
            <StackPanel x:Name="VideoPanel" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="WidthBox" Grid.Column="0" Header="Width" Text="1152"
                             Width="100" HorizontalAlignment="Left" />
                    <TextBox x:Name="HeightBox" Grid.Column="1" Header="Height" Text="768"
                             Width="100" HorizontalAlignment="Left" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NumFramesBox" Grid.Column="0" Header="Frames (8n+1)" Text="121"
                             Width="100" HorizontalAlignment="Left" />
                    <TextBox x:Name="FrameRateBox" Grid.Column="1" Header="Frame Rate" Text="24"
                             Width="100" HorizontalAlignment="Left" />
                </Grid>
                <TextBox x:Name="NegativePromptBox" Header="Negative Prompt"
                         PlaceholderText="What to avoid in the video"
                         Width="300" HorizontalAlignment="Left" />
                <TextBox x:Name="SeedBoxVideo" Header="Seed (optional)"
                         PlaceholderText="Leave empty for random"
                         Width="140" HorizontalAlignment="Left" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
