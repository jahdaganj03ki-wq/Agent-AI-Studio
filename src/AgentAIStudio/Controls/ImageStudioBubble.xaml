<UserControl x:Class="AgentAIStudio.Controls.ImageStudioBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AgentAIStudio.Controls">
    <Grid Margin="0,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Branch indicator -->
        <Border x:Name="BranchIndicator" Grid.Column="0"
                Width="24" Margin="0,0,4,0"
                Visibility="Collapsed">
            <Grid>
                <Rectangle x:Name="BranchLine" Width="2"
                           HorizontalAlignment="Center"
                           Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock x:Name="BranchLabel" FontSize="9"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,8,0,0"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>
        </Border>

        <Border x:Name="Bubble" Grid.Column="1"
                CornerRadius="12" Padding="12,8"
                MaxWidth="550" BorderThickness="0">
            <StackPanel Spacing="4">
                <TextBlock x:Name="RoleLabel" FontSize="11" FontWeight="SemiBold" />
                <TextBlock x:Name="PromptText" TextWrapping="Wrap" FontSize="13" />
                <Border x:Name="ImageBorder" Visibility="Collapsed" CornerRadius="8"
                        MaxWidth="400" MaxHeight="400" HorizontalAlignment="Left">
                    <Image x:Name="MediaImage" Stretch="Uniform" />
                </Border>
                <controls:MediaActionBar x:Name="ActionBar" Visibility="Collapsed" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
